# Database
DATABASE_URL="postgresql://user:password@localhost:5432/terodz"

# Auth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Admin account (used during db:seed)
ADMIN_EMAIL="admin@terodz.dz"
ADMIN_PASSWORD="your_secure_password"

# Email via Resend
RESEND_API_KEY="re_..."
EMAIL_FROM="Terodz <commandes@terodz.dz>"
OWNER_EMAIL="proprietaire@terodz.dz"

# Cloudinary
CLOUDINARY_CLOUD_NAME="..."
CLOUDINARY_API_KEY="..."
CLOUDINARY_API_SECRET="..."

# Business config (DZD or EUR)
CURRENCY="DZD"
NEXT_PUBLIC_SITE_URL="https://terodz.vercel.app"
